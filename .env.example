# Supabase (회원/주문). 실제 값은 .env.local 에 넣고 절대 커밋하지 마세요.
# Supabase 프로젝트 → Settings → API 에서 확인.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Solapi(국내) 문자/알림톡. 실제 값은 Netlify 환경변수로만 주입(절대 커밋 금지).
# 솔라피 콘솔 → 개발/연동 → API Key 에서 발급.
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
SOLAPI_FROM_NUMBER=01000000000

# 카카오 알림톡. pfId(채널 ID)·templateId 는 솔라피 검수 승인 후 발급되면 채운다.
# SOLAPI_PRIMARY_CHANNEL: 'ALIMTALK' 이면 알림톡 우선(+LMS 자동 대체), 그 외/미설정이면 LMS.
# 검수 승인 전에는 비워두거나 'LMS' 로 두고 운영하다, 승인 후 값만 바꿔 전환한다.
SOLAPI_PRIMARY_CHANNEL=LMS
SOLAPI_PFID=
SOLAPI_TEMPLATE_EXPIRE_SOON=
SOLAPI_TEMPLATE_PAYMENT_DEADLINE=
SOLAPI_TEMPLATE_PAYMENT_GUIDE=
SOLAPI_TEMPLATE_PAYMENT_CONFIRMED=
SOLAPI_TEMPLATE_WELCOME=
SOLAPI_TEMPLATE_SHIPPING=
SOLAPI_TEMPLATE_SUBSCRIPTION_CANCEL=
SOLAPI_TEMPLATE_GIFT_ARRIVAL=
SOLAPI_TEMPLATE_RENEW_GUIDE=
SOLAPI_TEMPLATE_RENEW_CONFIRMED=

# 가입 이탈 복구 크론용 공유 시크릿. Supabase Vault의 payment_recovery_secret 과 동일 값.
# (Netlify 환경변수로만 주입. 공개 repo 커밋 금지.)
PAYMENT_RECOVERY_SECRET=your-long-random-secret

# 재구독 만료 임박 알림 크론용 공유 시크릿. Supabase Vault의 renewal_reminder_secret 과 동일 값.
# (payment_recovery_secret 과 별개의 무작위 문자열. Netlify 환경변수로만 주입. 공개 repo 커밋 금지.)
RENEWAL_REMINDER_SECRET=your-long-random-secret

# PortOne(포트원) v2 결제. 가상계좌·카드·간편결제 통합.
# storeId/channelKey 는 브라우저에 노출되어도 안전(공개키) → NEXT_PUBLIC_.
#   포트원 관리자콘솔 → 연동 정보(상점/채널)에서 확인.
# 미설정 시에는 기존 무통장입금 안내 흐름으로 자동 폴백한다(라이브 무중단).
NEXT_PUBLIC_PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 아래 둘은 서버 전용 비밀값 → Netlify 환경변수로만 주입(절대 커밋 금지).
#   PORTONE_API_SECRET: 포트원 관리자콘솔 → API Keys 의 V2 API Secret (결제 단건 권위 조회용).
#   PORTONE_WEBHOOK_SECRET: 포트원 관리자콘솔 → 웹훅에 등록한 시크릿 (웹훅 서명 검증용).
PORTONE_API_SECRET=
PORTONE_WEBHOOK_SECRET=

# 웹훅 → DB 입금확인 RPC(confirm_payment) 호출용 공유 시크릿(서버 전용, 절대 커밋 금지).
# 같은 값을 Supabase Vault 시크릿 'confirm_payment_secret' 에도 저장한다.
#   (supabase/migration-portone-payment.sql 상단 안내 참고)
# PayAction 매칭완료 웹훅의 payaction_confirm RPC 호출에도 같은 시크릿을 재사용한다.
CONFIRM_PAYMENT_SECRET=

# ── PayAction(페이액션) 무통장입금 자동확인 ────────────────────────────
# 농협 계좌 입금을 PayAction 이 자동 매칭 → 매칭완료 웹훅으로 입금확인 처리.
# 모든 값은 서버 전용 비밀값 → Netlify 환경변수로만 주입(공개 repo 커밋 절대 금지).
#   PAYACTION_API_KEY: 주문 등록(POST /order) 인증용 API 키(페이액션 콘솔 발급).
#   PAYACTION_MALL_ID: 상점 ID. 등록·웹훅(x-mall-id) 대조에 사용.
#   PAYACTION_WEBHOOK_KEY: 웹훅 헤더(x-webhook-key) 검증용 키.
#   PAYACTION_API_BASE: 등록 API 베이스 URL(미설정 시 코드 기본값 사용).
# 미설정 시 무통장입금 주문은 등록을 건너뛴다(관리자 수동 처리, 주문 자체는 정상 접수).
PAYACTION_API_BASE=
PAYACTION_API_KEY=
PAYACTION_MALL_ID=
PAYACTION_WEBHOOK_KEY=

# ── 정기결제(빌링키 자동결제) ─────────────────────────────────────────
# 카드 빌링키로 주 1회 자동 청구하는 경로. (KCP/이니시스 카드 빌링 채널)
# 빌링 전용 채널키. 일반 결제 채널과 분리해 포트원 콘솔에서 발급(공개키 → NEXT_PUBLIC_).
#   미설정 시 정기결제 UI는 기존 1회 결제 흐름으로 폴백한다(라이브 무중단).
NEXT_PUBLIC_PORTONE_BILLING_CHANNEL_KEY=

# 빌링 RPC(store_billing_key/confirm_billing_charge 등) 호출용 공유 시크릿(서버 전용, 절대 커밋 금지).
# confirm_payment_secret 과 별개의 무작위 문자열을 쓴다(권한 분리).
# 같은 값을 Supabase Vault 시크릿 'billing_secret' 에도 저장한다.
#   (supabase/migration-billing.sql 상단 안내 참고)
BILLING_SECRET=
