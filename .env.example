# Supabase (회원/주문). 실제 값은 .env.local 에 넣고 절대 커밋하지 마세요.
# Supabase 프로젝트 → Settings → API 에서 확인.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Solapi(국내) 문자/알림톡. 실제 값은 Netlify 환경변수로만 주입(절대 커밋 금지).
# 솔라피 콘솔 → 개발/연동 → API Key 에서 발급.
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
SOLAPI_FROM_NUMBER=01000000000

# 카카오 알림톡. pfId(채널 ID)·templateId 는 솔라피 검수 승인 후 발급되면 채운다.
# SOLAPI_PRIMARY_CHANNEL: 'ALIMTALK' 이면 알림톡 우선(+LMS 자동 대체), 그 외/미설정이면 LMS.
# 검수 승인 전에는 비워두거나 'LMS' 로 두고 운영하다, 승인 후 값만 바꿔 전환한다.
SOLAPI_PRIMARY_CHANNEL=LMS
SOLAPI_PFID=
SOLAPI_TEMPLATE_EXPIRE_SOON=
SOLAPI_TEMPLATE_PAYMENT_DEADLINE=
SOLAPI_TEMPLATE_PAYMENT_GUIDE=
SOLAPI_TEMPLATE_PAYMENT_CONFIRMED=
SOLAPI_TEMPLATE_WELCOME=
SOLAPI_TEMPLATE_SHIPPED=
SOLAPI_TEMPLATE_SUBSCRIPTION_CANCELLED=
SOLAPI_TEMPLATE_GIFT_RECIPIENT=
